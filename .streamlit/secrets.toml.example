# Copy this file to secrets.toml and fill in your real values.
# secrets.toml is gitignored — never commit real credentials.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# On Streamlit Community Cloud, paste these same blocks into
# App settings → Secrets instead of committing the file.

[snowflake]
account   = "your-account-locator"      # e.g. orgname-accountname
user      = "YOUR_SNOWFLAKE_USER"
password  = "YOUR_SNOWFLAKE_PASSWORD"
warehouse = "NM_WH"
database  = "NM_ANALYTICS"
schema    = "RAW_MARTS"
role      = "SYSADMIN"

[anthropic]
api_key = "sk-ant-..."                   # your Anthropic API key
